# ══════════════════════════════════════════════════════════════════
# INVERSAVE — Variables de entorno
# ══════════════════════════════════════════════════════════════════
#
# CÓMO USAR:
#   1. Copiar este archivo: cp .env.example .env.local
#   2. Completar los valores
#   3. Reiniciar el servidor: npm run dev
#
# .env.local NO se sube al repositorio (está en .gitignore por Next.js)
# ══════════════════════════════════════════════════════════════════


# ── FRED API (Federal Reserve Economic Data) ──────────────────────
#
# Registrar gratis en: https://fred.stlouisfed.org/docs/api/api_key.html
#
# Activa la integración automática de:
#   - Tasa de Fondos Federales (FEDFUNDS)
#   - Bono del Tesoro 10 años (DGS10)
#   - Bono del Tesoro 2 años (DGS2)
#   - CPI EE.UU. (CPIAUCSL)
#
# Sin esta variable, estos indicadores aparecen como "Pendiente".
#
FRED_API_KEY=your_fred_api_key_here


# ── (Futuro) BCU API ──────────────────────────────────────────────
#
# El BCU no tiene una API REST pública estándar actualmente.
# Los datos del BCU se actualizan mediante:
#   1. PDFs en src/data-sources/pdfs/ + npm run update:indicators
#   2. Actualización manual en src/data/market.ts
#
# BCU_API_KEY=


# ── (Futuro) Notificaciones / email ──────────────────────────────
#
# Para alertas de actualización de datos o formulario de contacto.
#
# RESEND_API_KEY=
# FROM_EMAIL=noreply@inversave.com
